<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F4F6FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Login"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginTop="40dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign in using your registered admin email to receive a one-time verification code."
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="30dp"/>

        <!-- Email Label -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin Email"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="#333333"/>

        <!-- Email Field -->

        <EditText
            android:id="@+id/adminEmail"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="6dp"
            android:hint="e.g. xxxxxxx68@gmail.com"
            android:inputType="textEmailAddress"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"/>

        <!-- Send OTP Button -->

        <Button
            android:id="@+id/sendOtpBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Send Verification Code"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#3F51B5"
            android:textColor="#FFFFFF"/>

        <!-- OTP Label -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verification Code"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="#333333"
            android:layout_marginTop="30dp"/>

        <!-- OTP Field -->

        <EditText
            android:id="@+id/otpField"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="6dp"
            android:hint="Enter the 6-digit code"
            android:inputType="number"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"/>

        <!-- Submit Button -->

        <Button
            android:id="@+id/loginBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Verify and Login"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"/>

        <!-- Resend OTP -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Didn't receive the code? Resend"
            android:textSize="13sp"
            android:textColor="#3F51B5"
            android:layout_marginTop="15dp"
            android:layout_gravity="center"/>

    </LinearLayout>

</ScrollView>